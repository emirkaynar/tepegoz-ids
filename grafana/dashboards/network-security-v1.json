{
    "uid": "network-security-v1",
    "title": "Network Security Overview",
    "tags": ["ids", "influxdb", "grafana"],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 2,
    "refresh": "5s",
    "time": {
        "from": "now-15m",
        "to": "now"
    },
    "editable": false,
    "graphTooltip": 0,
    "templating": {
        "list": []
    },
    "annotations": {
        "list": []
    },
    "panels": [
        {
            "id": 1,
            "type": "timeseries",
            "title": "Traffic Rate",
            "datasource": {
                "type": "influxdb",
                "uid": "ids-influxdb"
            },
            "gridPos": {
                "x": 0,
                "y": 0,
                "w": 24,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {
                    "unit": "short"
                },
                "overrides": []
            },
            "options": {
                "legend": {
                    "showLegend": true,
                    "displayMode": "list",
                    "placement": "bottom"
                },
                "tooltip": {
                    "mode": "single",
                    "sort": "none"
                }
            },
            "targets": [
                {
                    "refId": "A",
                    "query": "from(bucket: \"ids_data\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"traffic_rollup\") |> filter(fn: (r) => r._field == \"packets_per_second\" or r._field == \"bytes_per_second\") |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false) |> group(columns:[\"protocol\", \"direction\", \"_field\"])",
                    "resultFormat": "time_series"
                }
            ]
        },
        {
            "id": 2,
            "type": "table",
            "title": "Top Hosts",
            "datasource": {
                "type": "influxdb",
                "uid": "ids-influxdb"
            },
            "gridPos": {
                "x": 0,
                "y": 8,
                "w": 12,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {},
                "overrides": []
            },
            "options": {
                "showHeader": true
            },
            "targets": [
                {
                    "refId": "B",
                    "query": "from(bucket: \"ids_data\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"top_hosts_rollup\") |> filter(fn: (r) => r._field == \"packet_count\" or r._field == \"byte_count\" or r._field == \"flow_count\") |> pivot(rowKey:[\"_time\", \"host_ip\", \"role\"], columnKey:[\"_field\"], valueColumn:\"_value\") |> sort(columns:[\"byte_count\"], desc:true) |> limit(n: 10)",
                    "resultFormat": "table"
                }
            ]
        },
        {
            "id": 3,
            "type": "table",
            "title": "Top Services",
            "datasource": {
                "type": "influxdb",
                "uid": "ids-influxdb"
            },
            "gridPos": {
                "x": 12,
                "y": 8,
                "w": 12,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {},
                "overrides": []
            },
            "options": {
                "showHeader": true
            },
            "targets": [
                {
                    "refId": "C",
                    "query": "from(bucket: \"ids_data\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"top_services_rollup\") |> filter(fn: (r) => r._field == \"packet_count\" or r._field == \"byte_count\" or r._field == \"flow_count\") |> pivot(rowKey:[\"_time\", \"service\", \"protocol\", \"port\"], columnKey:[\"_field\"], valueColumn:\"_value\") |> sort(columns:[\"byte_count\"], desc:true) |> limit(n: 10)",
                    "resultFormat": "table"
                }
            ]
        },
        {
            "id": 4,
            "type": "table",
            "title": "Recent Alerts",
            "datasource": {
                "type": "influxdb",
                "uid": "ids-influxdb"
            },
            "gridPos": {
                "x": 0,
                "y": 16,
                "w": 24,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {},
                "overrides": []
            },
            "options": {
                "showHeader": true
            },
            "targets": [
                {
                    "refId": "D",
                    "query": "from(bucket: \"ids_data\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"alerts\") |> filter(fn: (r) => r._field == \"src_ip\" or r._field == \"dst_ip\" or r._field == \"description\" or r._field == \"flow_key\") |> pivot(rowKey:[\"_time\", \"rule_name\", \"severity\", \"direction\"], columnKey:[\"_field\"], valueColumn:\"_value\") |> sort(columns:[\"_time\"], desc:true) |> limit(n: 100)",
                    "resultFormat": "table"
                }
            ]
        },
        {
            "id": 5,
            "type": "piechart",
            "title": "Protocol Distribution",
            "datasource": {
                "type": "influxdb",
                "uid": "ids-influxdb"
            },
            "gridPos": {
                "x": 0,
                "y": 24,
                "w": 24,
                "h": 8
            },
            "fieldConfig": {
                "defaults": {},
                "overrides": []
            },
            "options": {
                "pieType": "pie",
                "displayLabels": ["name", "value"]
            },
            "targets": [
                {
                    "refId": "E",
                    "query": "from(bucket: \"ids_data\") |> range(start: v.timeRangeStart, stop: v.timeRangeStop) |> filter(fn: (r) => r._measurement == \"traffic_rollup\" and r._field == \"packet_count\") |> group(columns: [\"protocol\", \"direction\"]) |> sum(column: \"_value\")",
                    "resultFormat": "time_series"
                }
            ]
        }
    ]
}
